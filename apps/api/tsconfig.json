{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "paths": {},
        "rootDir": "src",
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "es2017",
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "incremental": true,
        "noEmit": false
    },
    "include": [
        "src/**/*"
    ]
}